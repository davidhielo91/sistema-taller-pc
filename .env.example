# ================================================================
#  Sistema de Gestion para Taller de Reparacion de Computadoras
#  Archivo de configuracion de ejemplo
#
#  INSTRUCCIONES:
#  1. Copia este archivo a ".env":  cp .env.example .env
#  2. Edita los valores marcados con [CAMBIAR].
#  3. NUNCA subas el archivo ".env" a GitHub (ya esta en .gitignore).
# ================================================================


# ----------------------------------------------------------------
#  BASE DE DATOS
# ----------------------------------------------------------------
#
#  Formato: postgresql://USUARIO:CONTRASENA@HOST:PUERTO/NOMBRE_BD
#
#  >> Para Docker local (docker compose up):
#     No necesitas cambiar esta variable; docker-compose.yml la
#     fija internamente a la URL del contenedor de Postgres.
#
#  >> Para desarrollo sin Docker (npm run dev):
#     Apunta a tu PostgreSQL local, por ejemplo:
#     DATABASE_URL=postgresql://postgres:mi_pass@localhost:5432/taller_pc
#
#  >> Para EasyPanel:
#     Copia la URL interna que muestra EasyPanel al crear el
#     servicio de PostgreSQL. Tiene el formato:
#     postgresql://postgres:PASS@nombre-servicio:5432/taller_pc
#
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/taller_pc


# ----------------------------------------------------------------
#  SEGURIDAD DE SESION
#
#  !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
#  !!  CAMBIA ESTE VALOR ANTES DE EXPONER EL SISTEMA.         !!
#  !!  El sistema NO arrancara en produccion si este valor     !!
#  !!  sigue siendo "cambiar-por-un-secreto...".              !!
#  !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
#
#  Genera un valor seguro con este comando (requiere OpenSSL):
#    openssl rand -base64 32
#
#  En Windows (PowerShell):
#    [Convert]::ToBase64String((1..32 | %{ [byte](Get-Random -Max 256) }))
#
# ----------------------------------------------------------------
SESSION_SECRET=cambiar-por-un-secreto-seguro-en-produccion


# ----------------------------------------------------------------
#  USUARIO ADMINISTRADOR INICIAL
#
#  Se crea automaticamente en el primer arranque si no existe.
#  El proceso es idempotente: si el usuario ya existe, no hace nada.
#
#  !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
#  !!  CAMBIA ADMIN_PASSWORD por una contrasena segura.       !!
#  !!  "admin123" es solo para pruebas locales.               !!
#  !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
#
#  Nota: despues del primer arranque, el email y nombre del admin
#  NO se actualizan aunque cambies estas variables. Solo aplican
#  si el usuario aun no existe en la base de datos.
#
# ----------------------------------------------------------------
ADMIN_EMAIL=admin@taller.com
ADMIN_PASSWORD=admin123
ADMIN_NOMBRE=Administrador


# ----------------------------------------------------------------
#  CONFIGURACION DEL TALLER
#
#  Estos valores se guardan en la base de datos al primer
#  arranque (tabla Ajustes). Despues se pueden cambiar desde
#  la pantalla "Ajustes" dentro de la aplicacion (rol ADMIN).
#
#  Si ya existe un registro de Ajustes en la BD, estos valores
#  en .env NO sobreescriben los de la pantalla.
#
# ----------------------------------------------------------------

# Nombre visible del taller en la interfaz y en los comprobantes.
TALLER_NOMBRE=Mi Taller

# Moneda en formato ISO 4217.
# Ejemplos: MXN (Mexico), ARS (Argentina), COP (Colombia),
#           USD (dolares), EUR (euros), PEN (Peru), CLP (Chile)
TALLER_MONEDA=MXN
