generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Rol {
  ADMIN
  TECNICO
}

enum EstadoPago {
  PENDIENTE
  ABONADO
  PAGADO
}

enum EstadoOrden {
  RECIBIDO
  EN_DIAGNOSTICO
  PRESUPUESTADO
  APROBADO
  EN_REPARACION
  LISTO
  ENTREGADO
  NO_APROBADO
  CANCELADO
}

model Usuario {
  id           String   @id @default(cuid())
  nombre       String
  email        String   @unique
  passwordHash String
  rol          Rol      @default(TECNICO)
  activo       Boolean  @default(true)
  createdAt    DateTime @default(now())

  ordenesRecibidas  Orden[]           @relation("Recepcion")
  ordenesEntregadas Orden[]           @relation("Entrega")
  diagnosticos      Diagnostico[]
  historial         HistorialEstado[]
  pagos             Pago[]
}

model Cliente {
  id        String   @id @default(cuid())
  nombre    String
  telefono  String?
  email     String?
  documento String?
  notas     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ordenes Orden[]
}

model Orden {
  id        String   @id @default(cuid())
  folio     Int      @unique @default(autoincrement())

  cliente   Cliente  @relation(fields: [clienteId], references: [id])
  clienteId String

  tipoEquipo       String
  marca            String?
  modelo           String?
  serie            String?
  accesorios       String?
  fallaReportada   String
  estadoFisico     String?
  notasRecepcion   String?
  contrasenaEquipo String?

  fechaIngreso   DateTime @default(now())
  fechaPrometida DateTime?
  fechaEntrega   DateTime?

  estado     EstadoOrden @default(RECIBIDO)
  estadoPago EstadoPago  @default(PENDIENTE)
  costo      Decimal?    @db.Decimal(12, 2)

  trabajoRealizado String?
  notasEntrega     String?

  recibidoPor   Usuario  @relation("Recepcion", fields: [recibidoPorId], references: [id])
  recibidoPorId String
  entregadoPor   Usuario? @relation("Entrega", fields: [entregadoPorId], references: [id])
  entregadoPorId String?

  diagnosticos Diagnostico[]
  historial    HistorialEstado[]
  pagos        Pago[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Diagnostico {
  id      String @id @default(cuid())
  orden   Orden  @relation(fields: [ordenId], references: [id])
  ordenId String

  hallazgos         String
  solucionPropuesta String?
  costoEstimado     Decimal? @db.Decimal(12, 2)
  aprobado          Boolean?

  tecnico   Usuario @relation(fields: [tecnicoId], references: [id])
  tecnicoId String

  createdAt DateTime @default(now())
}

model Pago {
  id        String   @id @default(cuid())
  orden     Orden    @relation(fields: [ordenId], references: [id])
  ordenId   String
  monto     Decimal  @db.Decimal(12, 2)
  metodo    String?
  nota      String?
  usuario   Usuario  @relation(fields: [usuarioId], references: [id])
  usuarioId String
  createdAt DateTime @default(now())
}

model HistorialEstado {
  id             String       @id @default(cuid())
  orden          Orden        @relation(fields: [ordenId], references: [id])
  ordenId        String
  estadoAnterior EstadoOrden?
  estadoNuevo    EstadoOrden
  usuario        Usuario      @relation(fields: [usuarioId], references: [id])
  usuarioId      String
  createdAt      DateTime     @default(now())
}

model Ajustes {
  id           Int    @id @default(1)
  nombreTaller String
  moneda       String @default("MXN")
  telefono     String?
  direccion    String?
  logoUrl      String?
  codigoPaisWhatsapp   String?
  mensajeWhatsappListo String?
}
